---
// Resources Center Page
import Layout from "../../layouts/Layout.astro";
---

<Layout title="Resources — OncologyIT">
  <div class="container mx-auto px-4 py-12">
    <h1 class="text-4xl font-bold mb-6">Oncology IT Resources</h1>
    <p class="text-xl text-gray-600 mb-8">Comprehensive tools, frameworks, and references for cancer technology implementation.</p>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mb-12">
      <a href="/resources/glossary" class="bg-white p-6 rounded-lg shadow-md border border-gray-200 hover:shadow-lg transition-shadow">
        <div class="text-3xl mb-4">📚</div>
        <h3 class="text-xl font-semibold mb-3">Comprehensive Glossary</h3>
        <p class="text-gray-600 mb-4">Clinical oncology, AI/ML, healthcare IT, regulatory, and business terminology with clinical context.</p>
        <div class="text-blue-600 font-medium">Browse Terms →</div>
      </a>
      
      <a href="/resources/frameworks" class="bg-white p-6 rounded-lg shadow-md border border-gray-200 hover:shadow-lg transition-shadow">
        <div class="text-3xl mb-4">📋</div>
        <h3 class="text-xl font-semibold mb-3">Framework Library</h3>
        <p class="text-gray-600 mb-4">Implementation templates, checklists, and roadmaps for AI adoption in oncology practices.</p>
        <div class="text-blue-600 font-medium">Explore Frameworks →</div>
      </a>
      
      <a href="/resources/research" class="bg-white p-6 rounded-lg shadow-md border border-gray-200 hover:shadow-lg transition-shadow">
        <div class="text-3xl mb-4">🔬</div>
        <h3 class="text-xl font-semibold mb-3">Research Database</h3>
        <p class="text-gray-600 mb-4">Curated database of key studies, clinical trials, and papers with evidence grading system.</p>
        <div class="text-blue-600 font-medium">Browse Research →</div>
      </a>
      
      <a href="/resources/tools" class="bg-white p-6 rounded-lg shadow-md border border-gray-200 hover:shadow-lg transition-shadow">
        <div class="text-3xl mb-4">⚙️</div>
        <h3 class="text-xl font-semibold mb-3">Tool Directory</h3>
        <p class="text-gray-600 mb-4">Evaluation framework for oncology technology tools with weighted scoring system.</p>
        <div class="text-blue-600 font-medium">Evaluate Tools →</div>
      </a>
      
      <a href="/resources/events" class="bg-white p-6 rounded-lg shadow-md border border-gray-200 hover:shadow-lg transition-shadow">
        <div class="text-3xl mb-4">📅</div>
        <h3 class="text-xl font-semibold mb-3">Event Calendar</h3>
        <p class="text-gray-600 mb-4">Comprehensive calendar of conferences, webinars, FDA workshops, and certification deadlines.</p>
        <div class="text-blue-600 font-medium">View Calendar →</div>
      </a>
      
      <a href="/resources/careers" class="bg-white p-6 rounded-lg shadow-md border border-gray-200 hover:shadow-lg transition-shadow">
        <div class="text-3xl mb-4">🎓</div>
        <h3 class="text-xl font-semibold mb-3">Career Center</h3>
        <p class="text-gray-600 mb-4">Job board, training programs, certification pathways, and career development resources.</p>
        <div class="text-blue-600 font-medium">Explore Careers →</div>
      </a>
    </div>
    
    <div class="bg-gray-50 p-8 rounded-lg border border-gray-200">
      <h2 class="text-2xl font-bold mb-4">About This Resource Center</h2>
      <p class="text-gray-700 mb-4">
        This comprehensive resource center is designed to support clinical leaders, technology teams, 
        and healthcare professionals navigating the intersection of oncology and technology. Each section 
        provides practical, actionable information with a focus on evidence-based implementation.
      </p>
      <p class="text-gray-700">
        Developed by Jivesh Sharma, M.D., drawing on 30+ years of clinical experience and health IT leadership.
      </p>
    </div>
  </div>
</Layout>
