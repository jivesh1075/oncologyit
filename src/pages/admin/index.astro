---
import Base from '../../layouts/Base.astro';
// In production, this would check session auth
// For now, it's a static page to define the layout
---
<Base title="Admin Dashboard — OncologyIT">
  <div class="admin-wrapper">
    <header class="admin-header">
      <h1>OncologyIT Admin</h1>
      <span class="admin-badge">Dashboard</span>
    </header>

    <!-- STATS ROW -->
    <div class="stats-grid">
      <div class="stat-card">
        <div class="stat-label">Newsletter Subscribers</div>
        <div class="stat-value" id="stat-subscribers">—</div>
        <div class="stat-delta positive">+12 this week</div>
      </div>
      <div class="stat-card">
        <div class="stat-label">Course Enrollments</div>
        <div class="stat-value" id="stat-enrollments">—</div>
        <div class="stat-delta positive">+3 this week</div>
      </div>
      <div class="stat-card">
        <div class="stat-label">Certificates Issued</div>
        <div class="stat-value" id="stat-certs">—</div>
        <div class="stat-delta">all time</div>
      </div>
      <div class="stat-card">
        <div class="stat-label">Revenue (MTD)</div>
        <div class="stat-value" id="stat-revenue">—</div>
        <div class="stat-delta positive">+$447</div>
      </div>
      <div class="stat-card">
        <div class="stat-label">Page Views (7d)</div>
        <div class="stat-value" id="stat-views">—</div>
        <div class="stat-delta positive">+18%</div>
      </div>
      <div class="stat-card">
        <div class="stat-label">Bot Actions (24h)</div>
        <div class="stat-value" id="stat-bot">—</div>
        <div class="stat-delta">ALFRED: 8 · Jarvis: 4</div>
      </div>
    </div>

    <!-- TWO COLUMN LAYOUT -->
    <div class="admin-grid">
      <!-- LEFT: CONTENT & NEWSLETTER -->
      <div class="admin-col">
        <!-- NEWSLETTER QUEUE -->
        <div class="admin-card">
          <div class="card-header">
            <h2>Newsletter Queue</h2>
            <a href="/admin/newsletter" class="card-action">Manage →</a>
          </div>
          <div class="queue-list">
            <div class="queue-item draft">
              <span class="queue-status">DRAFT</span>
              <div class="queue-content">
                <strong>Weekly Dispatch #14 — AI Agent Governance</strong>
                <span class="queue-meta">Generated by ALFRED · Mar 24, 2026</span>
              </div>
              <div class="queue-actions">
                <button class="btn-sm btn-preview">Preview</button>
                <button class="btn-sm btn-approve">Approve</button>
              </div>
            </div>
            <div class="queue-item scheduled">
              <span class="queue-status">SCHEDULED</span>
              <div class="queue-content">
                <strong>Weekly Dispatch #13 — HIMSS Recap</strong>
                <span class="queue-meta">Sends: Tue Mar 25 @ 7:00 AM CT</span>
              </div>
              <div class="queue-actions">
                <button class="btn-sm btn-preview">Preview</button>
              </div>
            </div>
            <div class="queue-item sent">
              <span class="queue-status">SENT</span>
              <div class="queue-content">
                <strong>Weekly Dispatch #12 — SaaS to Labor</strong>
                <span class="queue-meta">Sent: Mar 18 · 847 recipients · 42% open</span>
              </div>
              <div class="queue-actions">
                <button class="btn-sm btn-preview">View</button>
              </div>
            </div>
          </div>
        </div>

        <!-- PUBLISHED CONTENT -->
        <div class="admin-card">
          <div class="card-header">
            <h2>Published Content</h2>
            <a href="/admin/content" class="card-action">All content →</a>
          </div>
          <div class="content-list">
            <div class="content-item">
              <span class="content-type article">Article</span>
              <strong>The Payer-Provider AI Arms Race</strong>
              <span class="content-stats">342 views · 12 shares</span>
            </div>
            <div class="content-item">
              <span class="content-type podcast">Podcast</span>
              <strong>EP 024: Fast Takeoff in Healthcare</strong>
              <span class="content-stats">1,204 plays · 38 min avg</span>
            </div>
            <div class="content-item">
              <span class="content-type article">Article</span>
              <strong>HIMSS 2026: What Actually Mattered</strong>
              <span class="content-stats">287 views · 8 shares</span>
            </div>
          </div>
        </div>
      </div>

      <!-- RIGHT: BOT ACTIVITY & COURSE -->
      <div class="admin-col">
        <!-- BOT ACTIVITY -->
        <div class="admin-card">
          <div class="card-header">
            <h2>Bot Activity</h2>
            <a href="/admin/bots" class="card-action">Full log →</a>
          </div>
          <div class="activity-log">
            <div class="activity-item">
              <span class="bot-tag alfred">ALFRED</span>
              <span class="activity-text">Published article: "Payer-Provider AI Arms Race"</span>
              <span class="activity-time">2h ago</span>
            </div>
            <div class="activity-item">
              <span class="bot-tag alfred">ALFRED</span>
              <span class="activity-text">Generated newsletter draft #14</span>
              <span class="activity-time">4h ago</span>
            </div>
            <div class="activity-item">
              <span class="bot-tag jarvis">JARVIS</span>
              <span class="activity-text">Scraped 14 new PubMed abstracts (oncology + AI)</span>
              <span class="activity-time">6h ago</span>
            </div>
            <div class="activity-item">
              <span class="bot-tag jarvis">JARVIS</span>
              <span class="activity-text">Updated toolkit: added 2 new AI tools</span>
              <span class="activity-time">8h ago</span>
            </div>
            <div class="activity-item">
              <span class="bot-tag alfred">ALFRED</span>
              <span class="activity-text">Built + deployed site (commit a3f2b1c)</span>
              <span class="activity-time">12h ago</span>
            </div>
            <div class="activity-item">
              <span class="bot-tag jarvis">JARVIS</span>
              <span class="activity-text">Flagged 3 content opportunities from FDA/CMS feeds</span>
              <span class="activity-time">14h ago</span>
            </div>
          </div>
        </div>

        <!-- COURSE METRICS -->
        <div class="admin-card">
          <div class="card-header">
            <h2>Course: AI Foundations</h2>
            <a href="/admin/course" class="card-action">Details →</a>
          </div>
          <div class="course-metrics">
            <div class="metric-row">
              <span>Enrolled</span>
              <strong>47</strong>
            </div>
            <div class="metric-row">
              <span>Completed (passed)</span>
              <strong>31</strong>
            </div>
            <div class="metric-row">
              <span>Average score</span>
              <strong>87%</strong>
            </div>
            <div class="metric-row">
              <span>Avg. completion time</span>
              <strong>4.2 hours</strong>
            </div>
            <div class="metric-row">
              <span>Revenue (all time)</span>
              <strong>$7,003</strong>
            </div>
          </div>
          <div class="module-completion">
            <h3>Module Completion Rates</h3>
            <div class="progress-bars">
              <div class="prog-row"><span>Mod 1: What Is AI</span><div class="prog-bar"><div class="prog-fill" style="width:98%"></div></div><span>98%</span></div>
              <div class="prog-row"><span>Mod 2: ML Fundamentals</span><div class="prog-bar"><div class="prog-fill" style="width:94%"></div></div><span>94%</span></div>
              <div class="prog-row"><span>Mod 3: LLMs Clinical</span><div class="prog-bar"><div class="prog-fill" style="width:89%"></div></div><span>89%</span></div>
              <div class="prog-row"><span>Mod 4: Applications</span><div class="prog-bar"><div class="prog-fill" style="width:83%"></div></div><span>83%</span></div>
              <div class="prog-row"><span>Mod 5: Regulatory</span><div class="prog-bar"><div class="prog-fill" style="width:78%"></div></div><span>78%</span></div>
              <div class="prog-row"><span>Mod 6: Implementation</span><div class="prog-bar"><div class="prog-fill" style="width:74%"></div></div><span>74%</span></div>
              <div class="prog-row"><span>Mod 7: Ethics &amp; Bias</span><div class="prog-bar"><div class="prog-fill" style="width:70%"></div></div><span>70%</span></div>
              <div class="prog-row"><span>Mod 8: Future</span><div class="prog-bar"><div class="prog-fill" style="width:66%"></div></div><span>66%</span></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</Base>

<style>
.admin-wrapper {
  max-width: 1200px;
  margin: 0 auto;
  padding: 6rem 2rem 4rem;
}
.admin-header {
  display: flex;
  align-items: center;
  gap: 1rem;
  margin-bottom: 2.5rem;
}
.admin-header h1 {
  font-family: var(--serif);
  font-size: 2rem;
  font-weight: 900;
}
.admin-badge {
  font-family: var(--mono);
  font-size: 0.62rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  background: var(--accent-light);
  color: var(--accent);
  padding: 0.3rem 0.75rem;
  border-radius: 100px;
}

/* Stats */
.stats-grid {
  display: grid;
  grid-template-columns: repeat(6, 1fr);
  gap: 1rem;
  margin-bottom: 2rem;
}
.stat-card {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 1.25rem;
}
.stat-label {
  font-size: 0.72rem;
  font-weight: 600;
  color: var(--text-muted);
  text-transform: uppercase;
  letter-spacing: 0.05em;
  margin-bottom: 0.5rem;
}
.stat-value {
  font-family: var(--serif);
  font-size: 1.75rem;
  font-weight: 700;
}
.stat-delta {
  font-size: 0.72rem;
  color: var(--text-muted);
  margin-top: 0.25rem;
}
.stat-delta.positive { color: var(--teal); }

/* Grid */
.admin-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1.5rem;
}
.admin-col { display: flex; flex-direction: column; gap: 1.5rem; }

/* Cards */
.admin-card {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 1.5rem;
}
.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 1.25rem;
  padding-bottom: 0.75rem;
  border-bottom: 1px solid var(--border);
}
.card-header h2 {
  font-family: var(--serif);
  font-size: 1.1rem;
  font-weight: 700;
}
.card-action {
  font-size: 0.78rem;
  font-weight: 600;
  color: var(--text-dim);
}
.card-action:hover { color: var(--accent); text-decoration: none; }

/* Newsletter Queue */
.queue-list { display: flex; flex-direction: column; gap: 0.75rem; }
.queue-item {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  padding: 0.75rem;
  border-radius: 6px;
  background: var(--bg);
}
.queue-status {
  font-family: var(--mono);
  font-size: 0.58rem;
  letter-spacing: 0.1em;
  font-weight: 500;
  padding: 0.2rem 0.5rem;
  border-radius: 3px;
  white-space: nowrap;
}
.draft .queue-status { background: rgba(200,160,40,0.12); color: #9a7b1a; }
.scheduled .queue-status { background: var(--teal-light); color: var(--teal); }
.sent .queue-status { background: rgba(0,0,0,0.04); color: var(--text-muted); }
.queue-content { flex: 1; }
.queue-content strong { font-size: 0.85rem; display: block; }
.queue-meta { font-size: 0.72rem; color: var(--text-muted); }
.queue-actions { display: flex; gap: 0.4rem; }
.btn-sm {
  font-size: 0.7rem;
  font-weight: 600;
  padding: 0.3rem 0.6rem;
  border-radius: 4px;
  border: 1px solid var(--border);
  background: var(--bg-card);
  color: var(--text-dim);
  cursor: pointer;
}
.btn-sm:hover { border-color: var(--border-strong); }
.btn-approve { background: var(--teal); color: #fff; border-color: var(--teal); }
.btn-approve:hover { opacity: 0.85; }

/* Content List */
.content-list { display: flex; flex-direction: column; gap: 0.5rem; }
.content-item {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  padding: 0.6rem 0;
  border-bottom: 1px solid var(--border);
  font-size: 0.85rem;
}
.content-item:last-child { border-bottom: none; }
.content-type {
  font-family: var(--mono);
  font-size: 0.55rem;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  padding: 0.2rem 0.5rem;
  border-radius: 3px;
  white-space: nowrap;
}
.content-type.article { background: var(--accent-light); color: var(--accent); }
.content-type.podcast { background: var(--purple-light); color: var(--purple); }
.content-stats {
  margin-left: auto;
  font-size: 0.72rem;
  color: var(--text-muted);
  white-space: nowrap;
}

/* Activity Log */
.activity-log { display: flex; flex-direction: column; gap: 0.6rem; }
.activity-item {
  display: flex;
  align-items: center;
  gap: 0.6rem;
  font-size: 0.82rem;
  padding: 0.5rem 0;
  border-bottom: 1px solid var(--border);
}
.activity-item:last-child { border-bottom: none; }
.bot-tag {
  font-family: var(--mono);
  font-size: 0.55rem;
  letter-spacing: 0.08em;
  font-weight: 500;
  padding: 0.2rem 0.5rem;
  border-radius: 3px;
  white-space: nowrap;
}
.bot-tag.alfred { background: var(--teal-light); color: var(--teal); }
.bot-tag.jarvis { background: var(--purple-light); color: var(--purple); }
.activity-text { flex: 1; color: var(--text-dim); }
.activity-time { font-size: 0.7rem; color: var(--text-muted); white-space: nowrap; }

/* Course Metrics */
.course-metrics {
  display: flex;
  flex-direction: column;
  gap: 0;
}
.metric-row {
  display: flex;
  justify-content: space-between;
  padding: 0.6rem 0;
  border-bottom: 1px solid var(--border);
  font-size: 0.85rem;
}
.metric-row span { color: var(--text-dim); }
.metric-row strong { color: var(--text); }
.metric-row:last-child { border-bottom: none; }

.module-completion {
  margin-top: 1.25rem;
  padding-top: 1.25rem;
  border-top: 1px solid var(--border);
}
.module-completion h3 {
  font-size: 0.82rem;
  font-weight: 700;
  margin-bottom: 0.75rem;
}
.progress-bars { display: flex; flex-direction: column; gap: 0.4rem; }
.prog-row {
  display: grid;
  grid-template-columns: 140px 1fr 35px;
  gap: 0.6rem;
  align-items: center;
  font-size: 0.72rem;
  color: var(--text-dim);
}
.prog-bar {
  height: 6px;
  background: var(--bg);
  border-radius: 3px;
  overflow: hidden;
}
.prog-fill {
  height: 100%;
  background: var(--teal);
  border-radius: 3px;
  transition: width 0.6s ease;
}

/* Responsive */
@media (max-width: 1000px) {
  .stats-grid { grid-template-columns: repeat(3, 1fr); }
  .admin-grid { grid-template-columns: 1fr; }
}
@media (max-width: 600px) {
  .stats-grid { grid-template-columns: repeat(2, 1fr); }
}
</style>
