---
import Layout from '../../layouts/Layout.astro';
import { CATEGORIES, getVendorsByCategory } from '../../data/vendors';
import VendorCard from '../../components/VendorCard.astro';

export async function getStaticPaths() {
  return CATEGORIES.map(category => ({
    params: { category: category.id }
  }));
}

const { category } = Astro.params;
const categoryData = CATEGORIES.find(c => c.id === category);
const vendors = getVendorsByCategory(category);
---

<Layout title={categoryData?.name || 'Category Not Found'}>
  <div class="container mx-auto px-4 py-8">
    {categoryData ? (
      <div class="max-w-6xl mx-auto">
        <h1 class="text-4xl font-bold mb-2">{categoryData.name}</h1>
        <p class="text-gray-600 mb-8">{categoryData.description}</p>
        
        <div class="mb-8">
          <a href="/vendors" class="text-accent hover:underline">← Back to All Categories</a>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {vendors.map(vendor => (
            <VendorCard vendor={vendor} />
          ))}
        </div>
        
        {vendors.length === 0 && (
          <div class="text-center py-12">
            <p class="text-gray-500">No vendors found in this category yet.</p>
          </div>
        )}
      </div>
    ) : (
      <div class="text-center py-12">
        <h2 class="text-2xl font-bold mb-4">Category Not Found</h2>
        <a href="/vendors" class="inline-block bg-accent text-white px-6 py-3 rounded-lg hover:bg-accent-dark transition-colors">
          Browse All Categories
        </a>
      </div>
    )}
  </div>
</Layout>
