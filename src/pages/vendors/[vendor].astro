---
import Layout from '../../layouts/Layout.astro';
import { getVendorById } from '../../data/vendors';

export async function getStaticPaths() {
  const vendors = [
    { params: { vendor: 'epic-systems' } },
    { params: { vendor: 'varian-medical' } },
    { params: { vendor: 'tempus' } },
    { params: { vendor: 'flatiron-health' } }
  ];
  return vendors;
}

const { vendor } = Astro.params;
const vendorData = getVendorById(vendor);
---

<Layout title={vendorData?.name || 'Vendor Not Found'}>
  <div class="container mx-auto px-4 py-8">
    {vendorData ? (
      <div class="max-w-4xl mx-auto">
        <h1 class="text-4xl font-bold mb-6">{vendorData.name}</h1>
        <div class="bg-white rounded-lg shadow-lg p-6 mb-6">
          <h2 class="text-2xl font-semibold mb-4">Company Overview</h2>
          <p class="mb-4">{vendorData.description}</p>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">
            <div>
              <h3 class="font-semibold">Founded</h3>
              <p>{vendorData.founded}</p>
            </div>
            <div>
              <h3 class="font-semibold">Headquarters</h3>
              <p>{vendorData.headquarters}</p>
            </div>
            {vendorData.employees && (
              <div>
                <h3 class="font-semibold">Employees</h3>
                <p>{vendorData.employees}</p>
              </div>
            )}
            {vendorData.revenue && (
              <div>
                <h3 class="font-semibold">Revenue</h3>
                <p>{vendorData.revenue}</p>
              </div>
            )}
          </div>
          
          <h2 class="text-2xl font-semibold mb-4">Oncology Focus Areas</h2>
          <ul class="list-disc pl-5 mb-6">
            {vendorData.oncologyFocus.map((focus, index) => (
              <li key={index} class="mb-2">{focus}</li>
            ))}
          </ul>
          
          <h2 class="text-2xl font-semibold mb-4">Key Products</h2>
          <ul class="list-disc pl-5 mb-6">
            {vendorData.keyProducts.map((product, index) => (
              <li key={index} class="mb-2">{product}</li>
            ))}
          </ul>
          
          <h2 class="text-2xl font-semibold mb-4">Recent Developments</h2>
          <ul class="list-disc pl-5">
            {vendorData.recentDevelopments.map((dev, index) => (
              <li key={index} class="mb-2">{dev}</li>
            ))}
          </ul>
          
          <div class="mt-8 pt-6 border-t">
            <a href={vendorData.website} target="_blank" rel="noopener noreferrer" 
               class="inline-block bg-accent text-white px-6 py-3 rounded-lg hover:bg-accent-dark transition-colors">
              Visit Official Website →
            </a>
          </div>
        </div>
        
        <div class="mt-6">
          <a href="/vendors" class="text-accent hover:underline">← Back to Vendor Directory</a>
        </div>
      </div>
    ) : (
      <div class="text-center py-12">
        <h2 class="text-2xl font-bold mb-4">Vendor Not Found</h2>
        <p class="mb-6">The vendor you're looking for doesn't exist in our directory.</p>
        <a href="/vendors" class="inline-block bg-accent text-white px-6 py-3 rounded-lg hover:bg-accent-dark transition-colors">
          Browse All Vendors
        </a>
      </div>
    )}
  </div>
</Layout>
