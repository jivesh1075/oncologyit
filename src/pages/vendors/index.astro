---
import Layout from '../../layouts/Layout.astro';
import { CATEGORIES, getAllVendors } from '../../data/vendors';
import VendorCard from '../../components/VendorCard.astro';

const vendors = getAllVendors();
---

<Layout title="Oncology IT Vendor Directory">
  <div class="container mx-auto px-4 py-8">
    <div class="max-w-6xl mx-auto">
      <h1 class="text-4xl font-bold mb-4">Oncology IT Vendor Directory</h1>
      <p class="text-gray-600 mb-8">
        Explore leading technology companies transforming cancer care through EHR systems, 
        radiation oncology, precision medicine, and clinical analytics.
      </p>
      
      <div class="mb-12">
        <h2 class="text-2xl font-bold mb-6">Browse by Category</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
          {CATEGORIES.map(category => (
            <a 
              href={`/vendors/${category.id}`}
              class="block bg-white rounded-lg shadow-md p-6 hover:shadow-lg transition-shadow"
            >
              <h3 class="text-lg font-semibold mb-2">{category.name}</h3>
              <p class="text-sm text-gray-600">{category.description}</p>
              <div class="mt-4 text-accent font-medium">
                Explore →
              </div>
            </a>
          ))}
        </div>
      </div>
      
      <div class="mb-12">
        <h2 class="text-2xl font-bold mb-6">Featured Vendors</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {vendors.map(vendor => (
            <VendorCard vendor={vendor} />
          ))}
        </div>
      </div>
      
      <div class="bg-gray-50 rounded-lg p-6">
        <h2 class="text-xl font-bold mb-4">About This Directory</h2>
        <p class="mb-4">
          This directory is curated to help oncology professionals discover and evaluate 
          technology solutions for cancer care. Each vendor profile includes company overview, 
          oncology focus areas, key products, and recent developments.
        </p>
        <p>
          Looking for a specific vendor or technology? 
          <a href="/contact" class="text-accent hover:underline ml-1">Contact us</a> with suggestions.
        </p>
      </div>
    </div>
  </div>
</Layout>
