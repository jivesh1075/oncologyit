---
// Vendor Directory Page
import Base from "../../layouts/Base.astro";
---

<Base title="Vendor Directory — OncologyIT">
  <div class="container mx-auto px-4 py-12">
    <h1 class="text-4xl font-bold mb-6">Oncology IT Vendor Directory</h1>
    <p class="text-xl text-gray-600 mb-8">Comprehensive directory of technology vendors serving oncology practices and health systems.</p>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-12">
      <div class="bg-white p-6 rounded-lg shadow-md border border-gray-200">
        <h3 class="text-xl font-semibold mb-3">EMR/EHR Systems</h3>
        <p class="text-gray-600 mb-4">Electronic medical record and health record systems for oncology practices.</p>
        <a href="/vendors/emr-systems" class="text-blue-600 font-medium hover:text-blue-800">Browse Vendors →</a>
      </div>
      
      <div class="bg-white p-6 rounded-lg shadow-md border border-gray-200">
        <h3 class="text-xl font-semibold mb-3">Oncology-Specific</h3>
        <p class="text-gray-600 mb-4">Specialized solutions designed specifically for cancer care.</p>
        <a href="/vendors/oncology-specific" class="text-blue-600 font-medium hover:text-blue-800">Browse Vendors →</a>
      </div>
      
      <div class="bg-white p-6 rounded-lg shadow-md border border-gray-200">
        <h3 class="text-xl font-semibold mb-3">AI/ML Platforms</h3>
        <p class="text-gray-600 mb-4">Artificial intelligence and machine learning solutions for oncology.</p>
        <a href="/vendors/ai-platforms" class="text-blue-600 font-medium hover:text-blue-800">Browse Vendors →</a>
      </div>
      
      <div class="bg-white p-6 rounded-lg shadow-md border border-gray-200">
        <h3 class="text-xl font-semibold mb-3">Data Analytics</h3>
        <p class="text-gray-600 mb-4">Analytics and business intelligence tools for cancer centers.</p>
        <a href="/vendors/data-analytics" class="text-blue-600 font-medium hover:text-blue-800">Browse Vendors →</a>
      </div>
    </div>
    
    <div class="bg-gray-50 p-8 rounded-lg border border-gray-200">
      <h2 class="text-2xl font-bold mb-4">About This Directory</h2>
      <p class="text-gray-700 mb-4">
        This comprehensive directory features 50+ major technology vendors serving the oncology IT landscape. 
        Each vendor profile includes company overview, oncology focus areas, key products, market position, 
        and recent developments.
      </p>
      <p class="text-gray-700">
        Curated by Jivesh Sharma, M.D., with a focus on practical implementation insights for clinical leaders.
      </p>
    </div>
  </div>
</Base>
