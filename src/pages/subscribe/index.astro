---
import Base from '../../layouts/Base.astro';
---
<Base title="Subscribe — OncologyIT" description="Get the weekly dispatch on AI, health IT, and the systems reshaping oncology.">
  <div class="subscribe-page">
    <div class="subscribe-inner">
      <div class="sub-badge">Weekly Dispatch</div>
      <h1>The weekly <em>signal</em> in<br>oncology technology.</h1>
      <p class="sub-desc">One dispatch per week. No vendor spin. No sponsored takes. What's actually changing in cancer care, AI, and health IT — analyzed by a practicing oncologist who builds the technology.</p>

      <form class="sub-form" action="/api/subscribe" method="POST">
        <input type="email" name="email" placeholder="you@hospital.org" required>
        <button type="submit" class="btn-accent">Subscribe</button>
      </form>
      <div class="sub-note">Free. Unsubscribe anytime. No spam, ever.</div>

      <div class="sub-preview">
        <h2>What You'll Get</h2>
        <div class="preview-grid">
          <div class="preview-card">
            <div class="preview-icon">📡</div>
            <h4>Signal Report</h4>
            <p>The 3-5 developments that actually matter this week in oncology AI, health IT, and clinical technology.</p>
          </div>
          <div class="preview-card">
            <div class="preview-icon">🔬</div>
            <h4>Deep Analysis</h4>
            <p>One key topic unpacked with clinical context — FDA decisions, vendor moves, infrastructure shifts.</p>
          </div>
          <div class="preview-card">
            <div class="preview-icon">🛠️</div>
            <h4>Builder's Corner</h4>
            <p>Tools, frameworks, and practical resources for teams deploying AI in oncology settings.</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</Base>

<style>
.subscribe-page {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 8rem 2rem 5rem;
}
.subscribe-inner {
  max-width: 600px;
  text-align: center;
}
.sub-badge {
  display: inline-block;
  font-family: var(--mono);
  font-size: 0.68rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--teal);
  background: var(--teal-light);
  padding: 0.4rem 1rem;
  border-radius: 100px;
  margin-bottom: 2rem;
}
.subscribe-inner h1 {
  font-family: var(--serif);
  font-size: clamp(2.2rem, 5vw, 3rem);
  font-weight: 900;
  line-height: 1.12;
  letter-spacing: -0.02em;
  margin-bottom: 1.25rem;
}
.subscribe-inner h1 em {
  font-style: italic;
  font-weight: 400;
  color: var(--accent);
}
.sub-desc {
  font-size: 1.05rem;
  color: var(--text-dim);
  line-height: 1.7;
  margin-bottom: 2.5rem;
}
.sub-form {
  display: flex;
  gap: 0.6rem;
  max-width: 460px;
  margin: 0 auto;
}
.sub-form input {
  flex: 1;
  padding: 0.85rem 1.2rem;
  border: 1.5px solid var(--border-strong);
  border-radius: 100px;
  font-family: var(--sans);
  font-size: 0.9rem;
  background: var(--bg-card);
  outline: none;
  transition: border-color 0.25s;
}
.sub-form input:focus { border-color: var(--accent); }
.sub-form input::placeholder { color: var(--text-muted); }
.sub-note {
  margin-top: 0.75rem;
  font-size: 0.75rem;
  color: var(--text-muted);
}
.sub-preview {
  margin-top: 4rem;
  padding-top: 3rem;
  border-top: 1px solid var(--border);
}
.sub-preview h2 {
  font-family: var(--serif);
  font-size: 1.4rem;
  font-weight: 700;
  margin-bottom: 1.75rem;
}
.preview-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.25rem;
  text-align: left;
}
.preview-card {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 1.5rem;
}
.preview-icon { font-size: 1.4rem; margin-bottom: 0.75rem; }
.preview-card h4 { font-size: 0.88rem; font-weight: 700; margin-bottom: 0.4rem; }
.preview-card p { font-size: 0.78rem; color: var(--text-dim); line-height: 1.55; }
@media (max-width: 900px) {
  .preview-grid { grid-template-columns: 1fr; }
  .sub-form { flex-direction: column; }
}
</style>
