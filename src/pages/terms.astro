  </div>

  <style>
    .page-header {
      text-align: center;
      margin-bottom: 3rem;
    }
    
    .page-header h1 {
      font-size: 2.5rem;
      margin-bottom: 0.5rem;
      color: var(--primary);
    }
    
    .subtitle {
      font-size: 1.1rem;
      color: var(--text-light);
    }
    
    .content {
      background: white;
      border-radius: var(--radius);
      padding: 3rem;
      box-shadow: var(--shadow);
    }
    
    section {
      margin-bottom: 3rem;
    }
    
    h2 {
      font-size: 1.5rem;
      margin-bottom: 1rem;
      color: var(--text);
      padding-bottom: 0.5rem;
      border-bottom: 1px solid var(--border);
    }
    
    p {
      line-height: 1.7;
      color: var(--text);
      margin-bottom: 1rem;
    }
    
    ul {
      list-style: none;
      padding: 0;
      margin: 1rem 0;
    }
    
    li {
      padding: 0.5rem 0;
      padding-left: 1.5rem;
      position: relative;
      color: var(--text);
    }
    
    li:before {
      content: "•";
      position: absolute;
      left: 0;
      color: var(--primary);
    }
    
    @media (max-width: 768px) {
      .page-header h1 {
        font-size: 2rem;
      }
      
      .content {
        padding: 2rem;
      }
    }
  </style>
</Layout>