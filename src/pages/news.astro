---
import Layout from '../layouts/Layout.astro';
---

<Layout 
  title="News" 
  description="Latest news and updates about oncology technology vendors and solutions">
  
  <div class="page-header">
    <h1>Oncology IT News</h1>
    <p class="subtitle">
      Latest developments, announcements, and insights from the oncology technology landscape
    </p>
  </div>

  <div class="coming-soon">
    <div class="coming-soon-content">
      <div class="coming-soon-icon">📰</div>
      <h2>News Section Coming Soon</h2>
      <p>
        We're currently building our news aggregation system to bring you the latest updates 
        from oncology technology vendors, including product launches, partnerships, clinical 
        studies, and regulatory developments.
      </p>
      <p>
        This section will feature curated news from across the oncology IT landscape, 
        organized by vendor, category, and topic.
      </p>
      <div class="coming-soon-actions">
        <a href="/vendors" class="cta-button">Browse Vendor Directory</a>
        <a href="/" class="secondary-button">Back to Home</a>
      </div>
    </div>
  </div>

  <style>
    .page-header {
      text-align: center;
      margin-bottom: 3rem;
    }
    
    .page-header h1 {
      font-size: 2.5rem;
      margin-bottom: 1rem;
      color: var(--primary);
    }
    
    .subtitle {
      font-size: 1.2rem;
      color: var(--text-light);
      max-width: 700px;
      margin: 0 auto;
    }
    
    .coming-soon {
      background: white;
      border-radius: var(--radius);
      padding: 4rem 2rem;
      box-shadow: var(--shadow);
      text-align: center;
      margin: 2rem 0;
    }
    
    .coming-soon-content {
      max-width: 600px;
      margin: 0 auto;
    }
    
    .coming-soon-icon {
      font-size: 4rem;
      margin-bottom: 2rem;
    }
    
    .coming-soon h2 {
      font-size: 2rem;
      margin-bottom: 1.5rem;
      color: var(--text);
    }
    
    .coming-soon p {
      line-height: 1.7;
      color: var(--text-light);
      margin-bottom: 1.5rem;
    }
    
    .coming-soon-actions {
      display: flex;
      justify-content: center;
      gap: 1rem;
      margin-top: 2rem;
      flex-wrap: wrap;
    }
    
    .cta-button {
      display: inline-block;
      background: var(--primary);
      color: white;
      text-decoration: none;
      padding: 1rem 2rem;
      border-radius: var(--radius);
      font-weight: 500;
      transition: background 0.2s;
    }
    
    .cta-button:hover {
      background: var(--primary-dark);
    }
    
    .secondary-button {
      display: inline-block;
      background: var(--secondary);
      color: var(--primary);
      text-decoration: none;
      padding: 1rem 2rem;
      border-radius: var(--radius);
      font-weight: 500;
      transition: background 0.2s;
    }
    
    .secondary-button:hover {
      background: #e0edff;
    }
    
    @media (max-width: 768px) {
      .page-header h1 {
        font-size: 2rem;
      }
      
      .subtitle {
        font-size: 1.1rem;
      }
      
      .coming-soon {
        padding: 3rem 1.5rem;
      }
      
      .coming-soon-actions {
        flex-direction: column;
        align-items: center;
      }
      
      .cta-button,
      .secondary-button {
        width: 100%;
        text-align: center;
      }
    }
  </style>
</Layout>