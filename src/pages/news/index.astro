---
// News Section Page
import Base from "../../layouts/Base.astro";
---

<Base title="Oncology IT News — OncologyIT">
  <div class="container mx-auto px-4 py-12">
    <h1 class="text-4xl font-bold mb-6">Oncology IT News</h1>
    <p class="text-xl text-gray-600 mb-8">Daily updates on AI, health IT, and technology transforming cancer care.</p>
    
    <div class="mb-8">
      <div class="flex space-x-4 mb-6">
        <button class="px-4 py-2 bg-blue-600 text-white rounded-lg font-medium">All News</button>
        <button class="px-4 py-2 bg-gray-200 text-gray-700 rounded-lg font-medium hover:bg-gray-300">AI & ML</button>
        <button class="px-4 py-2 bg-gray-200 text-gray-700 rounded-lg font-medium hover:bg-gray-300">EMR & EHR</button>
        <button class="px-4 py-2 bg-gray-200 text-gray-700 rounded-lg font-medium hover:bg-gray-300">Regulations</button>
      </div>
    </div>
    
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      <div class="lg:col-span-2 bg-white p-8 rounded-lg shadow-md border border-gray-200">
        <div class="mb-4">
          <span class="inline-block px-3 py-1 bg-green-100 text-green-800 text-sm font-medium rounded-full">AI & ML</span>
          <span class="text-gray-500 text-sm ml-3">March 26, 2026</span>
        </div>
        <h2 class="text-2xl font-bold mb-4">FDA Clears First Autonomous AI for Cancer Treatment Planning</h2>
        <p class="text-gray-700 mb-6">
          The FDA has granted clearance to an autonomous AI system that can generate radiation therapy plans 
          for certain cancer types without human intervention. This marks a significant milestone in the 
          clinical adoption of agentic AI systems in oncology.
        </p>
        <a href="#" class="text-blue-600 font-medium hover:text-blue-800">Read Full Article →</a>
      </div>
      
      <div class="bg-gray-50 p-6 rounded-lg border border-gray-200">
        <h3 class="text-xl font-bold mb-4">Recent Updates</h3>
        <div class="space-y-4">
          <div class="pb-4 border-b border-gray-200">
            <h4 class="font-semibold mb-1">Epic Launches Oncology AI Copilot</h4>
            <p class="text-sm text-gray-600 mb-2">March 25, 2026</p>
            <p class="text-sm text-gray-700">New AI assistant integrated into Epic's oncology module...</p>
          </div>
          <div class="pb-4 border-b border-gray-200">
            <h4 class="font-semibold mb-1">ASCO 2026: AI Clinical Trial Results</h4>
            <p class="text-sm text-gray-600 mb-2">March 24, 2026</p>
            <p class="text-sm text-gray-700">Phase III results for AI-driven treatment selection...</p>
          </div>
          <div>
            <h4 class="font-semibold mb-1">New HIPAA Guidance for AI Tools</h4>
            <p class="text-sm text-gray-600 mb-2">March 23, 2026</p>
            <p class="text-sm text-gray-700">Updated compliance requirements for healthcare AI...</p>
          </div>
        </div>
        
        <div class="mt-6 pt-6 border-t border-gray-200">
          <h4 class="font-semibold mb-3">Subscribe to Daily Updates</h4>
          <p class="text-sm text-gray-600 mb-3">Get the latest oncology IT news delivered to your inbox.</p>
          <a href="/subscribe" class="block w-full text-center px-4 py-2 bg-blue-600 text-white rounded-lg font-medium hover:bg-blue-700">
            Subscribe Now
          </a>
        </div>
      </div>
    </div>
    
    <div class="mt-12">
      <h3 class="text-2xl font-bold mb-6">News Categories</h3>
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4">
        <a href="/news/ai-ml" class="bg-green-50 p-4 rounded-lg border border-green-200 text-center hover:bg-green-100">
          <div class="text-green-600 font-semibold">AI & ML</div>
        </a>
        <a href="/news/emr-ehr" class="bg-blue-50 p-4 rounded-lg border border-blue-200 text-center hover:bg-blue-100">
          <div class="text-blue-600 font-semibold">EMR & EHR</div>
        </a>
        <a href="/news/regulations" class="bg-red-50 p-4 rounded-lg border border-red-200 text-center hover:bg-red-100">
          <div class="text-red-600 font-semibold">Regulations</div>
        </a>
        <a href="/news/funding" class="bg-yellow-50 p-4 rounded-lg border border-yellow-200 text-center hover:bg-yellow-100">
          <div class="text-yellow-600 font-semibold">Funding</div>
        </a>
        <a href="/news/clinical-trials" class="bg-purple-50 p-4 rounded-lg border border-purple-200 text-center hover:bg-purple-100">
          <div class="text-purple-600 font-semibold">Clinical Trials</div>
        </a>
        <a href="/news/technology" class="bg-indigo-50 p-4 rounded-lg border border-indigo-200 text-center hover:bg-indigo-100">
          <div class="text-indigo-600 font-semibold">Technology</div>
        </a>
      </div>
    </div>
  </div>
</Base>
