---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const episodes = (await getCollection('podcast', ({ data }) => !data.draft))
  .sort((a, b) => b.data.episodeNumber - a.data.episodeNumber);

const fmtDate = (d: Date) => d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
const slug = (id: string) => id.replace(/\.md$/, '');
---
<Base title="Podcast — OncologyIT" description="OncoTech AI Podcast: deep-dive conversations on AI, health IT, and oncology technology.">
  <div class="page-wrapper">
    <header class="page-header">
      <div class="podcast-badge">OncoTech AI Podcast</div>
      <h1>The Podcast</h1>
      <p>Deep-dive conversations on the systems, tools, and decisions reshaping oncology — from someone building them.</p>
    </header>
    <div class="episodes-list">
      {episodes.map((ep) => (
        <a href={`/podcast/${slug(ep.id)}`} class="episode-row">
          <div class="ep-number">EP {String(ep.data.episodeNumber).padStart(3, '0')}</div>
          <div class="ep-content">
            <h3>{ep.data.title}</h3>
            <p>{ep.data.description}</p>
            <div class="ep-meta">
              <span>{fmtDate(ep.data.date)}</span>
              <span class="sep">·</span>
              <span>{ep.data.duration}</span>
            </div>
          </div>
          <div class="ep-play">
            <div class="play-btn">
              <svg viewBox="0 0 10 12"><polygon points="0,0 10,6 0,12"/></svg>
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</Base>

<style>
.page-wrapper {
  max-width: var(--max-width);
  margin: 0 auto;
  padding: 8rem 2rem 5rem;
}
.page-header { margin-bottom: 3rem; text-align: center; }
.podcast-badge {
  display: inline-block;
  font-family: var(--mono);
  font-size: 0.68rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--accent);
  background: var(--accent-light);
  padding: 0.4rem 1rem;
  border-radius: 100px;
  margin-bottom: 1.5rem;
}
.page-header h1 {
  font-family: var(--serif);
  font-size: 2.5rem;
  font-weight: 900;
  letter-spacing: -0.02em;
}
.page-header p {
  margin-top: 0.75rem;
  font-size: 1.05rem;
  color: var(--text-dim);
  max-width: 520px;
  margin-left: auto;
  margin-right: auto;
  line-height: 1.65;
}
.episodes-list { display: flex; flex-direction: column; }
.episode-row {
  display: grid;
  grid-template-columns: 80px 1fr 60px;
  gap: 1.5rem;
  align-items: center;
  padding: 2rem 1.5rem;
  border-bottom: 1px solid var(--border);
  text-decoration: none !important;
  color: var(--text);
  transition: background 0.2s;
  border-radius: 8px;
}
.episode-row:first-child { border-top: 1px solid var(--border); }
.episode-row:hover { background: rgba(0,0,0,0.015); }
.ep-number {
  font-family: var(--mono);
  font-size: 0.72rem;
  letter-spacing: 0.12em;
  color: var(--accent);
  font-weight: 500;
}
.ep-content h3 {
  font-family: var(--serif);
  font-size: 1.25rem;
  font-weight: 700;
  line-height: 1.3;
  margin-bottom: 0.4rem;
}
.ep-content p {
  font-size: 0.88rem;
  color: var(--text-dim);
  line-height: 1.55;
  max-width: 600px;
}
.ep-meta {
  margin-top: 0.75rem;
  font-size: 0.78rem;
  color: var(--text-muted);
  display: flex;
  align-items: center;
  gap: 0.5rem;
}
.sep { color: var(--border-strong); }
.play-btn {
  width: 44px;
  height: 44px;
  border-radius: 50%;
  background: var(--accent);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: transform 0.2s, opacity 0.2s;
}
.episode-row:hover .play-btn { transform: scale(1.08); }
.play-btn svg { width: 14px; height: 14px; fill: #fff; margin-left: 2px; }
@media (max-width: 900px) {
  .episode-row { grid-template-columns: 1fr 50px; }
  .ep-number { display: none; }
}
</style>
