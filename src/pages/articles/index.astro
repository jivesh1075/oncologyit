---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const articles = (await getCollection('articles', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const tagClass = (tag: string) => `tag-${tag}`;
const fmtDate = (d: Date) => d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---
<Base title="Writing — OncologyIT" description="Analysis on AI, health IT, and oncology technology.">
  <div class="page-wrapper">
    <header class="page-header">
      <h1>Writing</h1>
      <p>Independent analysis at the intersection of oncology, AI, and health IT.</p>
    </header>
    <div class="articles-list">
      {articles.map((article) => (
        <a href={`/articles/${article.id}`} class="article-row">
          <span class="article-date">{fmtDate(article.data.date)}</span>
          <div class="article-content">
            <h3>{article.data.title}</h3>
            <p>{article.data.description}</p>
          </div>
          <span class={`tag-pill ${tagClass(article.data.tag)}`}>
            {article.data.tag.replace('-', ' ')}
          </span>
        </a>
      ))}
    </div>
  </div>
</Base>

<style>
.page-wrapper {
  max-width: var(--max-width);
  margin: 0 auto;
  padding: 8rem 2rem 5rem;
}
.page-header { margin-bottom: 3rem; }
.page-header h1 {
  font-family: var(--serif);
  font-size: 2.5rem;
  font-weight: 900;
  letter-spacing: -0.02em;
}
.page-header p {
  margin-top: 0.5rem;
  font-size: 1.05rem;
  color: var(--text-dim);
}
.articles-list { display: flex; flex-direction: column; }
.article-row {
  display: grid;
  grid-template-columns: 160px 1fr auto;
  gap: 2rem;
  align-items: baseline;
  padding: 1.75rem 0;
  border-bottom: 1px solid var(--border);
  text-decoration: none !important;
  color: var(--text);
  transition: background 0.2s;
}
.article-row:first-child { border-top: 1px solid var(--border); }
.article-row:hover { background: rgba(0,0,0,0.015); }
.article-date {
  font-family: var(--mono);
  font-size: 0.75rem;
  color: var(--text-muted);
}
.article-content h3 {
  font-family: var(--serif);
  font-size: 1.3rem;
  font-weight: 700;
  line-height: 1.3;
  margin-bottom: 0.4rem;
}
.article-content p {
  font-size: 0.88rem;
  color: var(--text-dim);
  max-width: 600px;
}
@media (max-width: 900px) {
  .article-row { grid-template-columns: 1fr; gap: 0.5rem; }
  .article-date { display: none; }
  .article-row .tag-pill { display: none; }
}
</style>
