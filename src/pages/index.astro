---
import Layout from '../layouts/Layout.astro';
---

<Layout 
  title="Home" 
  description="OncologyIT.com - Comprehensive directory of oncology technology vendors and solutions">
  
  <div class="hero">
    <h1>Oncology IT Vendor Directory</h1>
    <p class="hero-subtitle">
      Your comprehensive guide to technology solutions powering modern cancer care
    </p>
    <a href="/vendors" class="cta-button">Explore Vendor Directory →</a>
  </div>

  <div class="features">
    <div class="feature">
      <div class="feature-icon">📋</div>
      <h3>EHR/EMR Systems</h3>
      <p>Electronic health record systems specialized for oncology workflows and cancer care management.</p>
      <a href="/vendors/ehr-emr" class="feature-link">Explore EHR Vendors →</a>
    </div>
    
    <div class="feature">
      <div class="feature-icon">⚡</div>
      <h3>Radiation Oncology</h3>
      <p>Radiation therapy systems, treatment planning software, and oncology information systems.</p>
      <a href="/vendors/radiation-oncology" class="feature-link">Explore Radiation Vendors →</a>
    </div>
    
    <div class="feature">
      <div class="feature-icon">🧬</div>
      <h3>Genomics & Precision Medicine</h3>
      <p>AI-powered precision medicine platforms, genomic testing, and molecular diagnostics.</p>
      <a href="/vendors/genomics-precision-medicine" class="feature-link">Explore Genomics Vendors →</a>
    </div>
    
    <div class="feature">
      <div class="feature-icon">📊</div>
      <h3>Clinical Analytics</h3>
      <p>Real-world evidence platforms, clinical data analytics, and research database solutions.</p>
      <a href="/vendors/clinical-analytics" class="feature-link">Explore Analytics Vendors →</a>
    </div>
  </div>

  <div class="about-section">
    <h2>About OncologyIT.com</h2>
    <p>
      OncologyIT.com is a comprehensive directory of technology vendors serving the oncology space. 
      Our mission is to help healthcare professionals, IT leaders, and researchers discover and 
      evaluate the technology solutions that power modern cancer care.
    </p>
    <p>
      This directory is maintained by the <strong>Sharma Swarm</strong> initiative and is regularly 
      updated with new vendors, detailed profiles, and the latest developments in oncology technology.
    </p>
    <div class="about-actions">
      <a href="/vendors" class="secondary-button">Browse All Vendors</a>
      <a href="/about" class="text-button">Learn More About Us →</a>
    </div>
  </div>

  <style>
    .hero {
      text-align: center;
      padding: 4rem 0;
      margin-bottom: 4rem;
    }
    
    .hero h1 {
      font-size: 3rem;
      margin-bottom: 1.5rem;
      color: var(--primary);
    }
    
    .hero-subtitle {
      font-size: 1.3rem;
      color: var(--text-light);
      max-width: 700px;
      margin: 0 auto 2.5rem;
      line-height: 1.6;
    }
    
    .cta-button {
      display: inline-block;
      background: var(--primary);
      color: white;
      text-decoration: none;
      padding: 1rem 2rem;
      border-radius: var(--radius);
      font-size: 1.1rem;
      font-weight: 500;
      transition: background 0.2s, transform 0.2s;
    }
    
    .cta-button:hover {
      background: var(--primary-dark);
      transform: translateY(-2px);
    }
    
    .features {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 2rem;
      margin-bottom: 4rem;
    }
    
    .feature {
      background: white;
      border-radius: var(--radius);
      padding: 2rem;
      box-shadow: var(--shadow);
      text-align: center;
      transition: transform 0.2s, box-shadow 0.2s;
    }
    
    .feature:hover {
      transform: translateY(-4px);
      box-shadow: 0 8px 16px rgba(0,0,0,0.1);
    }
    
    .feature-icon {
      font-size: 3rem;
      margin-bottom: 1.5rem;
    }
    
    .feature h3 {
      font-size: 1.5rem;
      margin-bottom: 1rem;
      color: var(--text);
    }
    
    .feature p {
      color: var(--text-light);
      line-height: 1.6;
      margin-bottom: 1.5rem;
    }
    
    .feature-link {
      color: var(--primary);
      text-decoration: none;
      font-weight: 500;
      font-size: 0.95rem;
    }
    
    .feature-link:hover {
      text-decoration: underline;
    }
    
    .about-section {
      background: white;
      border-radius: var(--radius);
      padding: 3rem;
      box-shadow: var(--shadow);
      text-align: center;
    }
    
    .about-section h2 {
      font-size: 2rem;
      margin-bottom: 1.5rem;
      color: var(--text);
    }
    
    .about-section p {
      color: var(--text-light);
      line-height: 1.7;
      max-width: 800px;
      margin: 0 auto 1.5rem;
    }
    
    .about-actions {
      display: flex;
      justify-content: center;
      gap: 1.5rem;
      margin-top: 2rem;
      flex-wrap: wrap;
    }
    
    .secondary-button {
      display: inline-block;
      background: var(--secondary);
      color: var(--primary);
      text-decoration: none;
      padding: 0.75rem 1.5rem;
      border-radius: var(--radius);
      font-weight: 500;
      transition: background 0.2s;
    }
    
    .secondary-button:hover {
      background: #e0edff;
    }
    
    .text-button {
      color: var(--primary);
      text-decoration: none;
      font-weight: 500;
      padding: 0.75rem 0;
    }
    
    .text-button:hover {
      text-decoration: underline;
    }
    
    @media (max-width: 768px) {
      .hero h1 {
        font-size: 2.5rem;
      }
      
      .hero-subtitle {
        font-size: 1.1rem;
      }
      
      .features {
        grid-template-columns: 1fr;
      }
      
      .about-section {
        padding: 2rem;
      }
      
      .about-actions {
        flex-direction: column;
        align-items: center;
      }
    }
  </style>
</Layout>