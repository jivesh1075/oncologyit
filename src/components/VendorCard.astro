---
interface Props {
  vendor: {
    id: string;
    name: string;
    description: string;
    category: string;
    website: string;
    founded: number;
    headquarters: string;
  };
}

const { vendor } = Astro.props;
---

<div class="bg-white rounded-lg shadow-md overflow-hidden hover:shadow-lg transition-shadow">
  <div class="p-6">
    <div class="flex justify-between items-start mb-4">
      <h3 class="text-xl font-bold text-gray-900">{vendor.name}</h3>
      <span class="inline-block px-3 py-1 text-xs font-semibold rounded-full bg-gray-100 text-gray-800">
        {vendor.category.replace('-', ' ').toUpperCase()}
      </span>
    </div>
    
    <p class="text-gray-600 mb-4">{vendor.description}</p>
    
    <div class="space-y-2 text-sm text-gray-500 mb-6">
      <div class="flex items-center">
        <span class="font-medium mr-2">Founded:</span>
        <span>{vendor.founded}</span>
      </div>
      <div class="flex items-center">
        <span class="font-medium mr-2">HQ:</span>
        <span>{vendor.headquarters}</span>
      </div>
    </div>
    
    <div class="flex justify-between items-center">
      <a href={`/vendors/${vendor.id}`} class="text-accent font-medium hover:underline">
        View Details →
      </a>
      <a href={vendor.website} target="_blank" rel="noopener noreferrer" 
         class="text-sm bg-gray-100 hover:bg-gray-200 text-gray-800 px-4 py-2 rounded transition-colors">
        Website
      </a>
    </div>
  </div>
</div>
