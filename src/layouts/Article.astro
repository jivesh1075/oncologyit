---
import Base from './Base.astro';

const { frontmatter } = Astro.props;
const tagClass = `tag-${frontmatter.tag}`;
const dateStr = new Date(frontmatter.date).toLocaleDateString('en-US', {
  year: 'numeric', month: 'long', day: 'numeric'
});
---
<Base title={`${frontmatter.title} — OncologyIT`} description={frontmatter.description}>
  <article class="article-page">
    <header class="article-header">
      <div class="article-header-inner">
        <span class={`tag-pill ${tagClass}`}>{frontmatter.tag.replace('-', ' ')}</span>
        <h1>{frontmatter.title}</h1>
        <p class="article-desc">{frontmatter.description}</p>
        <div class="article-meta-row">
          <span>Jivesh Sharma, M.D.</span>
          <span class="sep">·</span>
          <span>{dateStr}</span>
          {frontmatter.readTime && (
            <>
              <span class="sep">·</span>
              <span>{frontmatter.readTime}</span>
            </>
          )}
        </div>
      </div>
    </header>
    <div class="article-body">
      <div class="prose">
        <slot />
      </div>
    </div>
  </article>
</Base>

<style>
.article-page { padding-top: 5rem; }
.article-header {
  padding: 4rem 2rem 3rem;
  text-align: center;
  border-bottom: 1px solid var(--border);
}
.article-header-inner {
  max-width: 720px;
  margin: 0 auto;
}
.article-header h1 {
  font-family: var(--serif);
  font-size: clamp(2rem, 4.5vw, 3rem);
  font-weight: 900;
  line-height: 1.15;
  letter-spacing: -0.02em;
  margin: 1rem 0 0.75rem;
}
.article-desc {
  font-size: 1.15rem;
  color: var(--text-dim);
  line-height: 1.6;
  margin-bottom: 1.5rem;
}
.article-meta-row {
  font-size: 0.82rem;
  color: var(--text-muted);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0.5rem;
}
.sep { color: var(--border-strong); }
.article-body {
  max-width: 720px;
  margin: 0 auto;
  padding: 3rem 2rem 5rem;
}
</style>
