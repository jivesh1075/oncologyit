# ─── Supabase ───
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Database (direct connection for migrations) ───
DATABASE_URL=postgresql://user:password@host:5432/database

# ─── Auth ───
NEXTAUTH_SECRET=generate-a-random-secret
ADMIN_EMAILS=admin@oncologyit.com

# ─── Stripe ───
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_PRICE_ID=price_xxx

# ─── Newsletter (Beehiiv) ───
BEEHIIV_API_KEY=your-beehiiv-key
BEEHIIV_PUBLICATION_ID=your-pub-id

# ─── Resend (transactional email) ───
RESEND_API_KEY=re_xxx
NEWSLETTER_FROM=dispatch@oncologyit.com

# ─── Bot / Mission Control ───
MISSION_CONTROL_URL=http://localhost:3001
BOT_AUTH_TOKEN=your-bot-token
MC_ENDPOINT=http://localhost:3777

# ─── Site ───
NEXT_PUBLIC_SITE_URL=https://www.oncologyit.com
