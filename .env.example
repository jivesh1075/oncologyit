# OncologyIT Environment Variables
# Copy to .env and fill in values

# Neon PostgreSQL
DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/oncologyit

# Stripe
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...

# Admin Auth
ADMIN_PASSWORD_HASH=$2b$12$...
SESSION_SECRET=change-me-to-64-random-chars

# Newsletter (Resend or similar)
RESEND_API_KEY=re_...
NEWSLETTER_FROM=dispatch@oncologyit.com

# Bot Config
MC_ENDPOINT=http://100.80.207.81:3777
